#!/bin/sh
# squash/bin/sq-mkmod — build add-on module layers
#
# Usage:
#   sq-mkmod preset <name>                 Build from preset
#   sq-mkmod from-dir <path> <NNN-name>    Squash a directory
#   sq-mkmod from-sandbox <id> <NNN-name>  Package sandbox upper as module
#   sq-mkmod list                          Show presets
#
# Presets download pre-built binaries and package them as squashfs layers.
# When stacked on a base, the sandbox gains that runtime.

set -eu

DATA="${SQUASH_DATA:-/data}"
MODULES="$DATA/modules"
WORK="/tmp/sq-mkmod.$$"

log() { echo "[sq-mkmod] $*"; }
die() { echo "[sq-mkmod] ERROR: $*" >&2; cleanup; exit 1; }
cleanup() { rm -rf "$WORK"; }
trap cleanup EXIT

squash_it() {
    local src="$1" name="$2" out="$MODULES/$name.squashfs"
    mkdir -p "$MODULES"
    local comp_args="-comp gzip -b 256K"
    if zgrep -q CONFIG_SQUASHFS_ZSTD=y /proc/config.gz 2>/dev/null; then
        comp_args="-comp zstd -Xcompression-level 15 -b 128K"
    fi
    mksquashfs "$src" "$out" $comp_args -noappend -quiet -no-xattrs -no-exports
    log "built: $name.squashfs ($(du -sh "$out" | cut -f1))"
    if [ -n "${SQUASH_S3_BUCKET:-}" ] && command -v sq-s3 >/dev/null 2>&1; then
        sq-s3 push-bg "$out" "modules/$name.squashfs"
    fi
}

# ── Python ─────────────────────────────────────────────────────────────
# Uses python-build-standalone for portable, pre-built CPython.

preset_python() {
    local ver="${1:-3.12}" root="$WORK/rootfs"
    local name="100-python${ver//./}"
    mkdir -p "$root/usr/local"

    log "building Python $ver module"

    # python-build-standalone provides self-contained CPython
    local tag="20241002"
    local pyarch=$(uname -m); case "$pyarch" in aarch64) pyarch=aarch64;; x86_64) pyarch=x86_64;; esac
    local url="https://github.com/indygreg/python-build-standalone/releases/download/$tag/cpython-${ver}+${tag}-${pyarch}-unknown-linux-gnu-install_only_stripped.tar.gz"

    log "downloading python-build-standalone"
    wget -qO "$WORK/python.tar.gz" "$url" 2>/dev/null || {
        # Fallback: try latest tag pattern
        log "WARN: exact URL failed, trying alternate"
        url="https://github.com/indygreg/python-build-standalone/releases/latest/download/cpython-${ver}-${pyarch}-unknown-linux-gnu-install_only_stripped.tar.gz"
        wget -qO "$WORK/python.tar.gz" "$url" 2>/dev/null || {
            log "WARN: pre-built download failed."
            log "Alternative: create sandbox, run 'apk add python3', then:"
            log "  sq-mkmod from-sandbox <id> $name"
            die "download failed"
        }
    }

    tar xzf "$WORK/python.tar.gz" -C "$root/usr/local" --strip-components=1

    # Ensure pip
    "$root/usr/local/bin/python3" -m ensurepip 2>/dev/null || true

    squash_it "$root" "$name"
}

# ── Node.js ────────────────────────────────────────────────────────────

preset_nodejs() {
    local ver="${1:-22}" root="$WORK/rootfs"
    local name="100-nodejs${ver}"
    mkdir -p "$root/usr/local"

    log "building Node.js $ver module"

    local index="https://nodejs.org/dist/latest-v${ver}.x/"
    local arch=$(uname -m); case "$arch" in aarch64) arch=arm64;; x86_64) arch=x64;; esac
    local tarball=$(wget -qO- "$index" 2>/dev/null | sed -n 's/.*href="\(node-v[0-9.]*-linux-'"$arch"'\.tar\.xz\)".*/\1/p' | head -1)
    [ -z "$tarball" ] && die "no Node.js $ver found"

    log "downloading $tarball"
    wget -qO "$WORK/node.tar.xz" "$index$tarball"
    tar xJf "$WORK/node.tar.xz" -C "$WORK"
    local extracted=$(ls -1d "$WORK"/node-v* | head -1)
    cp -a "$extracted"/{bin,lib,include} "$root/usr/local/" 2>/dev/null || true

    squash_it "$root" "$name"
}

# ── Go ─────────────────────────────────────────────────────────────────

preset_golang() {
    local root="$WORK/rootfs"
    local name="100-golang"
    mkdir -p "$root/usr/local"

    log "building Go module"

    local page=$(wget -qO- "https://go.dev/dl/" 2>/dev/null)
    local goarch=$(uname -m); case "$goarch" in aarch64) goarch=arm64;; x86_64) goarch=amd64;; esac
    local tarball=$(echo "$page" | sed -n 's/.*href="\(go[0-9.]*\.linux-'"$goarch"'\.tar\.gz\)".*/\1/p' | head -1)
    [ -z "$tarball" ] && die "no Go tarball found"

    log "downloading $tarball"
    wget -qO "$WORK/go.tar.gz" "https://go.dev/dl/$tarball"
    tar xzf "$WORK/go.tar.gz" -C "$root/usr/local"

    # PATH helper
    mkdir -p "$root/etc/profile.d"
    echo 'export PATH=/usr/local/go/bin:$PATH GOPATH=$HOME/go' > "$root/etc/profile.d/go.sh"

    squash_it "$root" "$name"
}

# ── Rust ───────────────────────────────────────────────────────────────

preset_rust() {
    local root="$WORK/rootfs"
    local name="100-rust"
    mkdir -p "$root/usr/local"

    log "building Rust module"
    log "NOTE: Rust is best installed inside a sandbox via rustup."
    log "  Create sandbox with base + 110-build-tools, then:"
    log "  exec: curl --proto '=https' -sSf https://sh.rustup.rs | sh -s -- -y"
    log "  sq-mkmod from-sandbox <id> $name"

    die "use sandbox-based install for Rust"
}

# ── Build tools (gcc, make, git, etc.) ─────────────────────────────────
# This is base-specific. For Alpine, we pack the dev packages.

preset_build_tools() {
    local root="$WORK/rootfs"
    local name="110-build-tools"
    mkdir -p "$root"

    log "building build-tools module"
    log "NOTE: this module is base-specific."
    log "For Alpine: create sandbox, exec 'apk add build-base git cmake'"
    log "Then: sq-mkmod from-sandbox <id> $name"

    die "use sandbox-based install for build-tools"
}

# ── Tailscale ──────────────────────────────────────────────────────────

preset_tailscale() {
    local root="$WORK/rootfs"
    local name="200-tailscale"
    mkdir -p "$root/usr/local/bin" "$root/usr/local/sbin"

    log "building Tailscale module"

    local page=$(wget -qO- "https://pkgs.tailscale.com/stable/" 2>/dev/null)
    local tsarch=$(uname -m); case "$tsarch" in aarch64) tsarch=arm64;; x86_64) tsarch=amd64;; esac
    local tarball=$(echo "$page" | sed -n 's/.*href="\(tailscale_[0-9.]*_'"$tsarch"'\.tgz\)".*/\1/p' | head -1)
    [ -z "$tarball" ] && die "no Tailscale tarball found"

    log "downloading $tarball"
    wget -qO "$WORK/ts.tgz" "https://pkgs.tailscale.com/stable/$tarball"
    tar xzf "$WORK/ts.tgz" -C "$WORK"

    local extracted=$(ls -1d "$WORK"/tailscale_* | head -1)
    cp "$extracted/tailscale"  "$root/usr/local/bin/"
    cp "$extracted/tailscaled" "$root/usr/local/sbin/"

    squash_it "$root" "$name"
}

# ── GUI base (XFCE + x11vnc + noVNC) ───────────────────────────────────
#
# Builds 500-gui-base.squashfs from the host distro's package manager
# (apk on Alpine, apt on Debian/Ubuntu). The result is a portable squashfs
# layer that, when stacked on a base sandbox, provides:
#   - Xvfb (in-memory X server)
#   - XFCE desktop (or set DESKTOP=minimal for a bare X session)
#   - x11vnc + websockify + noVNC (browser-accessible desktop on :6080)
#   - /usr/local/bin/sq-gui-start — the entrypoint squashd execs to start it
#   - /var/lib/sq-gui/browser-open.fifo — in-session browser command channel
#
# Runtime config is read from /etc/sq-gui.conf (DESKTOP, RESOLUTION,
# VNC_PORT, NOVNC_PORT, optional VNC_PASSWORD). squashd writes that file
# into the sandbox upper layer when GUI mode is enabled.

preset_gui_base() {
    local root="$WORK/rootfs" name="500-gui-base"
    mkdir -p "$root"

    log "building GUI base module ($name)"

    if command -v apk >/dev/null 2>&1; then
        log "using apk (Alpine) to populate rootfs"
        mkdir -p "$root/etc/apk"
        cp /etc/apk/repositories "$root/etc/apk/repositories" 2>/dev/null || true
        cp -a /etc/apk/keys "$root/etc/apk/" 2>/dev/null || true
        # --initdb so the result is self-contained; --no-cache to avoid leaking
        # the host's package index. The package list mirrors the README.
        apk add --root "$root" --initdb --no-cache \
            xvfb \
            xfce4 \
            xfce4-terminal \
            x11vnc \
            novnc \
            websockify \
            dbus-x11 \
            xauth \
            font-dejavu \
            >/dev/null 2>&1 || die "apk add failed (need root or fakeroot)"
    elif command -v debootstrap >/dev/null 2>&1 || command -v apt-get >/dev/null 2>&1; then
        log "Debian/Ubuntu host — recommended path is build-in-sandbox:"
        log "  1. sq-ctl create gui-builder anon 000-base-debian"
        log "  2. sq-ctl exec gui-builder 'apt-get update && apt-get install -y \\"
        log "       xvfb xfce4 xfce4-terminal x11vnc novnc websockify dbus-x11 xauth'"
        log "  3. sq-mkmod from-sandbox gui-builder $name"
        log "  4. sq-ctl destroy gui-builder"
        die "no automated apt path; use build-in-sandbox"
    else
        die "no supported package manager found (apk or apt)"
    fi

    # Drop in the entrypoint script. Lives inside the layer so it's available
    # in every sandbox that mounts this module.
    mkdir -p "$root/usr/local/bin"
    cat > "$root/usr/local/bin/sq-gui-start" <<'GUI_START_EOF'
#!/bin/sh
# sq-gui-start — boots the in-sandbox GUI stack.
# Sourced by squashd via `sq-exec ... sq-gui-start`. Reads /etc/sq-gui.conf
# for runtime parameters; falls back to sensible defaults.
set -eu

CONF="/etc/sq-gui.conf"
DESKTOP="xfce"
RESOLUTION="1920x1080"
VNC_PORT="5900"
NOVNC_PORT="6080"
VNC_PASSWORD=""
DISPLAY_NUM="99"

if [ -r "$CONF" ]; then
    # shellcheck disable=SC1090
    . "$CONF"
fi

export DISPLAY=":${DISPLAY_NUM}"
export HOME="${HOME:-/root}"
mkdir -p "$HOME"
mkdir -p /tmp/.X11-unix /var/log
chmod 1777 /tmp /tmp/.X11-unix 2>/dev/null || true

log() { echo "[sq-gui] $*"; }

uid="$(id -u 2>/dev/null || echo 0)"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp/sq-runtime-$uid}"
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR" 2>/dev/null || true
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$XDG_RUNTIME_DIR/bus}"
if command -v dbus-daemon >/dev/null 2>&1 && [ ! -S "$XDG_RUNTIME_DIR/bus" ]; then
    dbus-daemon --session --fork --address="$DBUS_SESSION_BUS_ADDRESS" \
        --print-pid >"$XDG_RUNTIME_DIR/dbus.pid" 2>/var/log/dbus.log || true
fi

start_browser_agent() {
    GUI_DIR="/var/lib/sq-gui"
    BROWSER_FIFO="$GUI_DIR/browser-open.fifo"
    mkdir -p "$GUI_DIR"
    rm -f "$BROWSER_FIFO"
    mkfifo "$BROWSER_FIFO" 2>/dev/null || {
        log "browser command channel unavailable"
        return 0
    }
    chmod 600 "$BROWSER_FIFO" 2>/dev/null || true
    (
        exec 3<>"$BROWSER_FIFO" || exit 0
        while :; do
            if IFS= read -r url <&3; then
                [ -n "$url" ] || continue
                if command -v sq-browser-open >/dev/null 2>&1; then
                    sq-browser-open "$url" >>/var/log/sq-browser-open.log 2>&1 &
                else
                    echo "[sq-gui] sq-browser-open not found; mount browser-base" >>/var/log/sq-browser-open.log
                fi
            else
                sleep 1
            fi
        done
    ) &
    log "browser command channel ready at $BROWSER_FIFO"
}

# Xvfb — virtual framebuffer
log "Xvfb $DISPLAY ${RESOLUTION}x24"
Xvfb "$DISPLAY" -screen 0 "${RESOLUTION}x24" -nolisten tcp -ac >/var/log/xvfb.log 2>&1 &
XVFB_PID=$!
sleep 2

# Window manager / desktop session
case "$DESKTOP" in
    xfce|xfce4)
        log "starting XFCE"
        if [ -S "$XDG_RUNTIME_DIR/bus" ]; then
            startxfce4 >/var/log/xfce.log 2>&1 &
        elif command -v dbus-launch >/dev/null 2>&1; then
            dbus-launch --exit-with-session startxfce4 >/var/log/xfce.log 2>&1 &
        else
            startxfce4 >/var/log/xfce.log 2>&1 &
        fi
        ;;
    minimal|none)
        log "minimal session — no window manager"
        ;;
    *)
        log "unknown DESKTOP=$DESKTOP — falling back to xterm"
        if command -v xterm >/dev/null 2>&1; then
            xterm >/var/log/xterm.log 2>&1 &
        fi
        ;;
esac
WM_PID=$!

# x11vnc — bridge X to VNC. Optional password.
VNC_AUTH_ARGS="-nopw"
if [ -n "$VNC_PASSWORD" ]; then
    VNC_PWFILE="$HOME/.vnc/passwd"
    mkdir -p "$HOME/.vnc"
    x11vnc -storepasswd "$VNC_PASSWORD" "$VNC_PWFILE" >/dev/null 2>&1 || true
    VNC_AUTH_ARGS="-rfbauth $VNC_PWFILE"
fi
log "x11vnc :$DISPLAY_NUM → tcp/$VNC_PORT"
# shellcheck disable=SC2086
x11vnc -display "$DISPLAY" -forever -shared -rfbport "$VNC_PORT" $VNC_AUTH_ARGS \
    >/var/log/x11vnc.log 2>&1 &
VNC_PID=$!

start_browser_agent

# websockify + noVNC. The novnc package usually drops files at /usr/share/novnc.
NOVNC_DIR="/usr/share/novnc"
if [ ! -d "$NOVNC_DIR" ] && [ -d "/usr/share/webapps/novnc" ]; then
    NOVNC_DIR="/usr/share/webapps/novnc"
fi
log "websockify $NOVNC_PORT → localhost:$VNC_PORT (web=$NOVNC_DIR)"
exec websockify --web="$NOVNC_DIR" "$NOVNC_PORT" "localhost:$VNC_PORT"
GUI_START_EOF
    chmod +x "$root/usr/local/bin/sq-gui-start"

    # Marker so sandboxes can detect the GUI layer is present.
    mkdir -p "$root/etc"
    echo "$name" > "$root/etc/sq-gui-module"

    squash_it "$root" "$name"
}

# ── Browser base (Chromium + desktop runtime glue) ──────────────────────
#
# Builds 510-browser-base.squashfs. Stack it with 500-gui-base and create the
# sandbox with features ["gui","browser"] so browser launches happen inside the
# same long-lived desktop session through sq-gui-start's FIFO command channel.

preset_browser_base() {
    local root="$WORK/rootfs" name="510-browser-base"
    mkdir -p "$root"

    log "building browser base module ($name)"

    if command -v apk >/dev/null 2>&1; then
        log "using apk (Alpine) to populate rootfs"
        mkdir -p "$root/etc/apk"
        cp /etc/apk/repositories "$root/etc/apk/repositories" 2>/dev/null || true
        cp -a /etc/apk/keys "$root/etc/apk/" 2>/dev/null || true
        apk add --root "$root" --initdb --no-cache \
            chromium \
            ca-certificates \
            nss \
            dbus \
            dbus-x11 \
            xdg-utils \
            font-dejavu \
            font-noto \
            mesa-dri-gallium \
            >/dev/null 2>&1 || die "apk add failed (need root or fakeroot)"
    elif command -v debootstrap >/dev/null 2>&1 || command -v apt-get >/dev/null 2>&1; then
        log "Debian/Ubuntu host — recommended path is build-in-sandbox:"
        log "  1. sq-ctl create browser-builder anon 000-base-debian"
        log "  2. sq-ctl exec browser-builder 'apt-get update && apt-get install -y \\"
        log "       chromium ca-certificates fonts-dejavu fonts-noto dbus-x11 xdg-utils'"
        log "  3. sq-mkmod from-sandbox browser-builder $name"
        log "  4. sq-ctl destroy browser-builder"
        die "no automated apt path; use build-in-sandbox"
    else
        die "no supported package manager found (apk or apt)"
    fi

    mkdir -p "$root/usr/local/bin" "$root/etc"
    cat > "$root/usr/local/bin/sq-browser-open" <<'BROWSER_OPEN_EOF'
#!/bin/sh
# sq-browser-open — run a browser inside the existing sq-gui-start session.
set -eu

URL="${1:-about:blank}"
case "$URL" in
    http://*|https://*|about:blank) ;;
    *) echo "unsupported browser URL: $URL" >&2; exit 64 ;;
esac

export DISPLAY="${DISPLAY:-:99}"
export HOME="${HOME:-/root}"
uid="$(id -u 2>/dev/null || echo 0)"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp/sq-runtime-$uid}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
mkdir -p "$XDG_RUNTIME_DIR" "$XDG_CACHE_HOME" "$XDG_CONFIG_HOME" "$HOME/Downloads"
chmod 700 "$XDG_RUNTIME_DIR" 2>/dev/null || true

export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$XDG_RUNTIME_DIR/bus}"
if command -v dbus-daemon >/dev/null 2>&1 && [ ! -S "$XDG_RUNTIME_DIR/bus" ]; then
    dbus-daemon --session --fork --address="$DBUS_SESSION_BUS_ADDRESS" \
        --print-pid >"$XDG_RUNTIME_DIR/dbus-browser.pid" 2>/tmp/sq-browser-dbus.log || true
fi

CHROME_FLAGS="
--user-data-dir=$XDG_CONFIG_HOME/sq-chromium
--disk-cache-dir=$XDG_CACHE_HOME/sq-chromium
--no-first-run
--no-default-browser-check
--disable-dev-shm-usage
--disable-gpu
--no-sandbox
"

if command -v chromium-browser >/dev/null 2>&1; then
    # shellcheck disable=SC2086
    exec chromium-browser $CHROME_FLAGS "$URL"
elif command -v chromium >/dev/null 2>&1; then
    # shellcheck disable=SC2086
    exec chromium $CHROME_FLAGS "$URL"
elif command -v firefox >/dev/null 2>&1; then
    exec firefox --no-remote --new-window "$URL"
fi

echo "no supported browser found (expected chromium-browser, chromium, or firefox)" >&2
exit 127
BROWSER_OPEN_EOF
    chmod +x "$root/usr/local/bin/sq-browser-open"
    echo "$name" > "$root/etc/sq-browser-module"

    squash_it "$root" "$name"
}

# ── From directory or sandbox ──────────────────────────────────────────

from_dir() {
    local src="$1" name="$2"
    [ -d "$src" ] || die "not a directory: $src"
    squash_it "$src" "$name"
}

from_sandbox() {
    local id="$1" name="$2"
    local upper="$DATA/sandboxes/$id/upper"
    [ -d "$upper" ] || die "sandbox not found or empty upper: $id"
    squash_it "$upper" "$name"
}

# ── Main ───────────────────────────────────────────────────────────────
mkdir -p "$WORK"

case "${1:-help}" in
    preset)
        case "${2:-}" in
            python*)     preset_python "$(echo "$2" | sed -n 's/.*\([0-9][0-9.]*\)$/\1/p')" ;;
            node*|js*)   preset_nodejs "$(echo "$2" | sed -n 's/.*\([0-9][0-9]*\)$/\1/p')" ;;
            go|golang)   preset_golang ;;
            rust)        preset_rust ;;
            build*|dev*) preset_build_tools ;;
    tailscale)   preset_tailscale ;;
  sqlite-libs) preset_sqlite_libs ;;
  nullclaw)    preset_nullclaw ;;
            gui|gui-base) preset_gui_base ;;
            browser|browser-base) preset_browser_base ;;

            *)           die "unknown preset: ${2:-}. Run '$0 list'" ;;
        esac
        ;;
    from-dir)
        [ $# -lt 3 ] && die "usage: $0 from-dir <path> <NNN-name>"
        from_dir "$2" "$3"
        ;;
    from-sandbox)
        [ $# -lt 3 ] && die "usage: $0 from-sandbox <sandbox-id> <NNN-name>"
        from_sandbox "$2" "$3"
        ;;
    list)
        cat <<'EOF'
presets:
  python3.12   → 100-python312.squashfs    Python 3.12 (standalone)
  python3.11   → 100-python311.squashfs    Python 3.11
  nodejs22     → 100-nodejs22.squashfs     Node.js 22 LTS
  nodejs20     → 100-nodejs20.squashfs     Node.js 20 LTS
  golang       → 100-golang.squashfs       Go (latest)
  tailscale    → 200-tailscale.squashfs    Tailscale client
  gui-base     → 500-gui-base.squashfs     XFCE + x11vnc + noVNC desktop
  browser-base → 510-browser-base.squashfs Chromium + browser launch helper

build-in-sandbox (recommended for base-specific packages):
  1. sq-ctl create builder anon 000-base-alpine
  2. sq-ctl exec builder "apk add build-base git cmake python3 py3-pip"
  3. sq-mkmod from-sandbox builder 110-build-tools
  4. sq-ctl destroy builder

  The resulting module is portable across sandboxes with the same base.
EOF
        ;;
    help|*)
        echo "usage: $0 preset <name>                 Build from preset"
        echo "       $0 from-dir <path> <NNN-name>    Squash a directory"
        echo "       $0 from-sandbox <id> <NNN-name>  Package sandbox changes"
        echo "       $0 list                           Show presets"
        ;;
esac
