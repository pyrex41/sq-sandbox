{
    "_comment": "Read-only seccomp profile for sq-sandbox, inspired by denoland/ronly. Blocks destructive syscalls (file deletion, rename, truncate, kill, mount) while allowing normal read operations. Applied inside the sandbox when policy.seccomp_profile is 'readonly'.",
    "defaultAction": "SCMP_ACT_ALLOW",
    "syscalls": [
        {
            "names": [
                "unlink",
                "unlinkat",
                "rmdir",
                "rename",
                "renameat",
                "renameat2",
                "truncate",
                "ftruncate",
                "mount",
                "umount2",
                "reboot",
                "kexec_load",
                "kexec_file_load",
                "init_module",
                "finit_module",
                "delete_module",
                "bpf",
                "process_vm_readv",
                "process_vm_writev",
                "userfaultfd"
            ],
            "action": "SCMP_ACT_ERRNO",
            "errnoRet": 1,
            "comment": "Destructive filesystem ops + dangerous system calls blocked"
        },
        {
            "names": [
                "kill",
                "tkill",
                "tgkill"
            ],
            "action": "SCMP_ACT_ERRNO",
            "errnoRet": 1,
            "comment": "Signal delivery blocked — processes visible but not killable (ronly-style PID isolation)"
        }
    ]
}
