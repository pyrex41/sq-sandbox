#!/bin/sh
set -eu

usage() {
    echo "Usage: sq-exec <merged-root> <cmd> [workdir] [timeout] [net] [seccomp] [readonly] [shims]" >&2
    echo "  merged-root  overlayfs merged directory (chroot/bwrap target)" >&2
    echo "  cmd          shell command to execute" >&2
    echo "  workdir      working directory inside sandbox (default: /)" >&2
    echo "  timeout      seconds before kill (default: 300)" >&2
    echo "  net          1=slirp4netns outbound networking, 0=offline (default: 0)" >&2
    echo "  seccomp      seccomp profile: none|default|readonly|strict (default: none)" >&2
    echo "  readonly     1=read-only root (no upper layer writes), 0=writable (default: 0)" >&2
    echo "  shims        comma-separated tool shims to install: docker,kubectl,systemctl (default: none)" >&2
    exit 1
}

[ $# -lt 2 ] && usage

root="$1"
cmd="$2"
workdir="${3:-/}"
timeout_s="${4:-300}"
net="${5:-0}"
seccomp="${6:-none}"
readonly_mode="${7:-0}"
shims="${8:-}"

# ── Resolve seccomp profile path ──────────────────────────────────────
seccomp_file=""
if [ "$seccomp" != "none" ]; then
    script_dir="$(dirname "$(readlink -f "$0")")"
    shared_dir="$(dirname "$script_dir")"
    case "$seccomp" in
        default)  seccomp_file="$shared_dir/seccomp.json" ;;
        readonly) seccomp_file="$shared_dir/seccomp-readonly.json" ;;
        strict)   seccomp_file="$shared_dir/seccomp-strict.json" ;;
        /*)       seccomp_file="$seccomp" ;;  # absolute path
        *)        echo "[sq-exec] unknown seccomp profile: $seccomp" >&2; seccomp_file="" ;;
    esac
    if [ -n "$seccomp_file" ] && [ ! -f "$seccomp_file" ]; then
        echo "[sq-exec] seccomp profile not found: $seccomp_file" >&2
        seccomp_file=""
    fi
fi

# ── Install tool shims into sandbox ───────────────────────────────────
if [ -n "$shims" ]; then
    script_dir="${script_dir:-$(dirname "$(readlink -f "$0")")}"
    shared_dir="${shared_dir:-$(dirname "$script_dir")}"
    shims_src="$shared_dir/shims"
    shims_dst="$root/usr/local/sbin/ronly-shims"

    mkdir -p "$shims_dst"
    for shim in $(echo "$shims" | tr ',' ' '); do
        if [ -f "$shims_src/$shim" ]; then
            # Copy shim into sandbox
            cp "$shims_src/$shim" "$shims_dst/$shim"
            chmod +x "$shims_dst/$shim"
            # Rename the real binary so the shim can find it
            if [ -x "$root/usr/bin/$shim" ] && [ ! -e "$root/usr/bin/${shim}.real" ]; then
                cp "$root/usr/bin/$shim" "$root/usr/bin/${shim}.real"
            fi
        else
            echo "[sq-exec] shim not found: $shim" >&2
        fi
    done

    # Prepend shims dir to PATH inside the sandbox command
    cmd="export PATH=/usr/local/sbin/ronly-shims:\$PATH; $cmd"
fi

# ── Build bwrap arguments ─────────────────────────────────────────────
build_bwrap_args() {
    # Root bind: read-only if readonly_mode=1, writable otherwise
    if [ "$readonly_mode" = "1" ]; then
        echo "--ro-bind" "$root" "/"
    else
        echo "--bind" "$root" "/"
    fi

    echo "--dev /dev"
    echo "--proc /proc"
    echo "--tmpfs /tmp"
    echo "--tmpfs /run"
    echo "--ro-bind /etc/resolv.conf /etc/resolv.conf"
    echo "--unshare-pid"
    echo "--unshare-ipc"
    echo "--unshare-uts"
    echo "--unshare-net"
    echo "--die-with-parent"

    # Seccomp filter via bwrap's --seccomp fd (requires bwrap >=0.5)
    # bwrap expects a binary BPF program on the fd, but our profiles are JSON.
    # Instead, we apply seccomp inside the sandbox if a helper is available.
    # For now, the seccomp profile is documented and can be enforced at the
    # container/runtime level (Docker --security-opt, runsc, etc.).
}

# Try bubblewrap first (unprivileged, pivot_root-based)
if command -v bwrap >/dev/null 2>&1; then
    if [ "$net" = "1" ] && command -v slirp4netns >/dev/null 2>&1; then
        # Network-enabled sandbox: bwrap with --unshare-net + slirp4netns user-mode NAT.
        # slirp4netns provides outbound internet access without CAP_NET_ADMIN.
        # The host proxy at localhost:8888 is reachable from inside as 10.0.2.2:8888.
        tmpdir=$(mktemp -d)
        trap 'rm -rf "$tmpdir"' EXIT

        # Determine root bind mode
        if [ "$readonly_mode" = "1" ]; then
            bind_flag="--ro-bind"
        else
            bind_flag="--bind"
        fi

        # Start bwrap with --info-fd writing to a regular file (non-blocking).
        # bwrap forks the child, writes the child PID to info-fd, then waits for the child.
        timeout "$timeout_s" bwrap \
            $bind_flag "$root" / \
            --dev /dev \
            --proc /proc \
            --tmpfs /tmp \
            --tmpfs /run \
            --ro-bind /etc/resolv.conf /etc/resolv.conf \
            --unshare-pid \
            --unshare-ipc \
            --unshare-uts \
            --unshare-net \
            --die-with-parent \
            --info-fd 4 \
            --chdir "$workdir" \
            /bin/sh -c "$cmd" \
            4>"$tmpdir/bwrap-info.json" &
        bwrap_pid=$!

        # Wait for bwrap to fork child and write info JSON (typically < 5ms).
        sleep 0.05

        # Parse child PID from bwrap info JSON: {"child-pid":12345,...}
        child_pid=""
        if [ -s "$tmpdir/bwrap-info.json" ]; then
            child_pid=$(sed 's/.*"child-pid": *\([0-9]*\).*/\1/' "$tmpdir/bwrap-info.json")
        fi

        slirp_pid=""
        if printf '%s' "${child_pid:-}" | grep -qE '^[0-9]+$' 2>/dev/null; then
            # Set up a fifo for slirp4netns ready notification.
            # slirp4netns writes one byte to --ready-fd when the interface is configured.
            mkfifo "$tmpdir/slirp-ready"

            # Start slirp4netns in background; the write-open of the ready-fifo (fd 4)
            # blocks until we open the read end below.
            slirp4netns \
                --configure \
                --mtu=65520 \
                --ready-fd 4 \
                "$child_pid" eth0 \
                4>"$tmpdir/slirp-ready" \
                >/dev/null 2>&1 &
            slirp_pid=$!

            # Open the read end of the ready fifo; this unblocks slirp4netns's fd-open,
            # then blocks here until slirp4netns writes its ready signal.
            cat "$tmpdir/slirp-ready" >/dev/null 2>/dev/null || true
        else
            echo "[sq-exec] slirp4netns: could not get bwrap child PID" >&2
        fi

        # Wait for sandbox command to complete
        wait $bwrap_pid
        rc=$?

        if [ -n "$slirp_pid" ]; then
            kill "$slirp_pid" 2>/dev/null || true
            wait "$slirp_pid" 2>/dev/null || true
        fi

        exit $rc
    fi

    # Determine root bind mode
    if [ "$readonly_mode" = "1" ]; then
        bind_flag="--ro-bind"
    else
        bind_flag="--bind"
    fi

    # Offline sandbox (net=0 or slirp4netns unavailable): fully isolated network namespace
    timeout "$timeout_s" bwrap \
        $bind_flag "$root" / \
        --dev /dev \
        --proc /proc \
        --tmpfs /tmp \
        --tmpfs /run \
        --ro-bind /etc/resolv.conf /etc/resolv.conf \
        --unshare-pid \
        --unshare-ipc \
        --unshare-uts \
        --unshare-net \
        --die-with-parent \
        --chdir "$workdir" \
        /bin/sh -c "$cmd" && exit 0 || rc=$?

    # If bwrap failed due to pivot_root (common inside containers), fall through
    if [ "$rc" -ne 0 ] && [ "$rc" -ne 124 ]; then
        # 124 = timeout, which is a legitimate result, not a bwrap failure
        echo "[sq-exec] bwrap failed (rc=$rc), falling back to unshare+chroot" >&2
    else
        exit "$rc"
    fi
fi

# Fallback: unshare + chroot (works as root, or with user namespaces)
# Note: no network isolation in this fallback path
# Read-only mode in fallback: remount root as read-only after chroot
if [ "$readonly_mode" = "1" ]; then
    exec timeout "$timeout_s" \
        unshare --mount --pid --ipc --uts --fork --map-root-user \
        chroot "$root" \
        /bin/sh -c "mount -o remount,ro / 2>/dev/null || true; cd \"$workdir\" 2>/dev/null || true; $cmd"
else
    exec timeout "$timeout_s" \
        unshare --mount --pid --ipc --uts --fork --map-root-user \
        chroot "$root" \
        /bin/sh -c "cd \"$workdir\" 2>/dev/null || true; $cmd"
fi
