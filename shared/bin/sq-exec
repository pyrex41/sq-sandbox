#!/bin/sh
set -eu

usage() {
    echo "Usage: sq-exec <merged-root> <cmd> [workdir] [timeout] [net]" >&2
    echo "  merged-root  overlayfs merged directory (chroot/bwrap target)" >&2
    echo "  cmd          shell command to execute" >&2
    echo "  workdir      working directory inside sandbox (default: /)" >&2
    echo "  timeout      seconds before kill (default: 300)" >&2
    echo "  net          1=slirp4netns outbound networking, 0=offline (default: 0)" >&2
    exit 1
}

setup_chroot_mounts() {
    _root="$1"
    mkdir -p "$_root/dev" "$_root/proc" "$_root/tmp" "$_root/run" "$_root/etc"
    mount --rbind /dev "$_root/dev"
    mount --make-rslave "$_root/dev" 2>/dev/null || true
    mount -t proc proc "$_root/proc"
    mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs "$_root/tmp"
    mount -t tmpfs -o mode=755,nosuid,nodev tmpfs "$_root/run"
}

bind_resolv_conf() {
    _root="$1"
    _resolv="$2"
    _target="$_root/etc/resolv.conf"
    mkdir -p "$_root/etc"

    [ -e "$_target" ] || : > "$_target"

    mount --bind "$_resolv" "$_target"
}

run_chroot_payload() {
    _root="$1"
    exec chroot "$_root" /bin/sh -c '
        if [ -f /etc/profile.d/squash-secrets.sh ]; then
            . /etc/profile.d/squash-secrets.sh
        fi
        cd "$SQEXEC_WORKDIR" 2>/dev/null || true
        exec /bin/sh -c "$SQEXEC_CMD"
    '
}

internal_chroot() {
    _root="$1"
    _net="$2"
    _resolv="$3"
    _sync_fifo="$4"
    _pidfile="$5"

    setup_chroot_mounts "$_root"

    if [ "$_net" = "1" ] && [ "$_resolv" != "-" ]; then
        bind_resolv_conf "$_root" "$_resolv"
    elif [ -f /etc/resolv.conf ]; then
        bind_resolv_conf "$_root" /etc/resolv.conf
    fi

    if [ "$_pidfile" != "-" ]; then
        printf '%s\n' "$$" > "$_pidfile"
    fi
    if [ "$_sync_fifo" != "-" ]; then
        read _ < "$_sync_fifo"
    fi

    run_chroot_payload "$_root"
}

if [ "${1:-}" = "--internal-chroot" ]; then
    [ $# -eq 6 ] || exit 125
    shift
    internal_chroot "$@"
fi

[ $# -lt 2 ] && usage

root="$1"
cmd="$2"
workdir="${3:-/}"
timeout_s="${4:-300}"
net="${5:-0}"

# Try bubblewrap first (unprivileged, pivot_root-based)
if command -v bwrap >/dev/null 2>&1; then
    if [ "$net" = "1" ] && command -v slirp4netns >/dev/null 2>&1; then
        # Network-enabled sandbox: bwrap with --unshare-net + slirp4netns user-mode NAT.
        # slirp4netns provides outbound internet access without CAP_NET_ADMIN.
        # The host proxy at localhost:8888 is reachable from inside as 10.0.2.2:8888.
        tmpdir=$(mktemp -d)
        trap 'rm -rf "$tmpdir"' EXIT

        # Write resolv.conf pointing to slirp4netns DNS (10.0.2.3).
        # The host container's resolv.conf uses 127.0.0.11 (Docker's embedded DNS)
        # which is only reachable on the host loopback — not from inside the new
        # network namespace created by --unshare-net.  slirp4netns provides its own
        # DNS forwarder at 10.0.2.3 which IS reachable from the sandbox.
        printf 'nameserver 10.0.2.3\n' > "$tmpdir/resolv.conf"
        # Write slirp DNS config directly into the overlay root.
        # resolv.conf is pre-created in the upper layer by injectSecrets, so
        # this overwrites the host default with the slirp4netns forwarder.
        cp "$tmpdir/resolv.conf" "$root/etc/resolv.conf" 2>/dev/null || true

        # Network-ready synchronization gate (fd 3 inside sandbox).
        # The sandbox command is wrapped: "read _ <&3; exec sh -c '$cmd'".
        # The parent writes to this fifo after slirp4netns configures eth0,
        # which allows the sandbox to proceed.  This prevents a race where a
        # short-lived command (e.g. "ip addr") finishes before slirp4netns can
        # attach to the new network namespace.
        #
        # We open the fifo in O_RDWR mode (exec 9<>) in the parent to avoid
        # blocking: with a plain read-only or write-only open, the open(2) call
        # would block until the other end is also opened.
        mkfifo "$tmpdir/net-sync"
        exec 9<>"$tmpdir/net-sync"   # keep write end open on fd 9 (non-blocking)

        # Start bwrap with --info-fd writing to a regular file (non-blocking).
        # fd 3 (read end of net-sync) and fd 4 (info-fd output) are inherited by bwrap.
        # The wrapper command reads from fd 3 (blocking until parent signals ready)
        # then execs the real command.  SQEXEC_CMD carries the command safely via env
        # so no quoting of $cmd is required in the shell heredoc.
        SQEXEC_CMD="$cmd" timeout "$timeout_s" bwrap \
            --bind "$root" / \
            --dev /dev \
            --proc /proc \
            --tmpfs /tmp \
            --tmpfs /run \
            --unshare-pid \
            --unshare-ipc \
            --unshare-uts \
            --unshare-net \
            --die-with-parent \
            --info-fd 4 \
            --chdir "$workdir" \
            /bin/sh -c 'read _ <&3; if [ -f /etc/profile.d/squash-secrets.sh ]; then . /etc/profile.d/squash-secrets.sh; fi; exec /bin/sh -c "$SQEXEC_CMD"' \
            3<"$tmpdir/net-sync" \
            4>"$tmpdir/bwrap-info.json" &
        bwrap_pid=$!

        # Wait for bwrap to fork child and write info JSON (typically < 5ms).
        sleep 0.1

        # Parse child PID from bwrap info JSON (may be multi-line pretty-printed).
        # Use grep to isolate the child-pid line before extracting digits.
        child_pid=""
        if [ -s "$tmpdir/bwrap-info.json" ]; then
            child_pid=$(grep '"child-pid"' "$tmpdir/bwrap-info.json" | grep -o '[0-9]*')
        fi

        slirp_pid=""
        if printf '%s' "${child_pid:-}" | grep -qE '^[0-9]+$' 2>/dev/null; then
            # Set up a fifo for slirp4netns ready notification.
            # slirp4netns writes one byte to --ready-fd when the interface is configured.
            mkfifo "$tmpdir/slirp-ready"

            # Start slirp4netns in background; the write-open of the ready-fifo (fd 4)
            # blocks until we open the read end below.
            slirp4netns \
                --configure \
                --mtu=65520 \
                --ready-fd 4 \
                "$child_pid" eth0 \
                4>"$tmpdir/slirp-ready" \
                >/dev/null 2>&1 &
            slirp_pid=$!

            # Open the read end of the ready fifo; this unblocks slirp4netns's fd-open,
            # then blocks here until slirp4netns writes its ready signal.
            cat "$tmpdir/slirp-ready" >/dev/null 2>/dev/null || true
        else
            echo "[sq-exec] slirp4netns: could not get bwrap child PID" >&2
        fi

        # Network is ready (or failed).  Signal the sandbox to proceed by writing
        # to the net-sync fifo and then closing our write end (fd 9).
        printf 'go\n' >&9
        exec 9>&-

        # Wait for sandbox command to complete
        wait $bwrap_pid
        rc=$?

        if [ -n "$slirp_pid" ]; then
            kill "$slirp_pid" 2>/dev/null || true
            wait "$slirp_pid" 2>/dev/null || true
        fi

        exit $rc
    fi

    # Offline sandbox (net=0 or slirp4netns unavailable): fully isolated network namespace
    # resolv.conf is pre-created in the overlay by injectSecrets — no --ro-bind needed
    SQEXEC_CMD="$cmd" timeout "$timeout_s" bwrap \
        --bind "$root" / \
        --dev /dev \
        --proc /proc \
        --tmpfs /tmp \
        --tmpfs /run \
        --unshare-pid \
        --unshare-ipc \
        --unshare-uts \
        --unshare-net \
        --die-with-parent \
        --chdir "$workdir" \
        /bin/sh -c 'if [ -f /etc/profile.d/squash-secrets.sh ]; then . /etc/profile.d/squash-secrets.sh; fi; exec /bin/sh -c "$SQEXEC_CMD"' && exit 0 || rc=$?

    # If bwrap failed due to pivot_root (common inside containers), fall through
    if [ "$rc" -ne 0 ] && [ "$rc" -ne 124 ]; then
        # 124 = timeout, which is a legitimate result, not a bwrap failure
        echo "[sq-exec] bwrap failed (rc=$rc), falling back to unshare+chroot" >&2
    else
        exit "$rc"
    fi
fi

# Fallback: recreate the runtime mounts in a private mount namespace, then chroot.
# We avoid --map-root-user here because it would place the child in a separate user
# namespace and break slirp4netns access to the proxy-friendly net namespace.
if [ "$net" = "1" ]; then
    command -v slirp4netns >/dev/null 2>&1 || {
        echo "[sq-exec] network requested but slirp4netns is unavailable in fallback" >&2
        exit 126
    }

    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT
    printf 'nameserver 10.0.2.3\n' > "$tmpdir/resolv.conf"

    mkfifo "$tmpdir/net-sync"
    exec 9<>"$tmpdir/net-sync"
    mkfifo "$tmpdir/slirp-ready"

    SQEXEC_CMD="$cmd" SQEXEC_WORKDIR="$workdir" timeout "$timeout_s" \
        unshare --mount --pid --ipc --uts --net --fork \
        "$0" --internal-chroot "$root" 1 "$tmpdir/resolv.conf" "$tmpdir/net-sync" "$tmpdir/child.pid" &
    child_wrapper_pid=$!

    child_pid=""
    i=0
    while [ $i -lt 100 ]; do
        if [ -s "$tmpdir/child.pid" ]; then
            child_pid=$(tr -d '\n' < "$tmpdir/child.pid")
            break
        fi
        if ! kill -0 "$child_wrapper_pid" 2>/dev/null; then
            break
        fi
        sleep 0.05
        i=$((i + 1))
    done

    if ! printf '%s' "${child_pid:-}" | grep -qE '^[0-9]+$' 2>/dev/null; then
        echo "[sq-exec] fallback: could not get child PID for slirp4netns" >&2
        kill "$child_wrapper_pid" 2>/dev/null || true
        wait "$child_wrapper_pid" 2>/dev/null || true
        exit 1
    fi

    slirp4netns \
        --configure \
        --mtu=65520 \
        --ready-fd 4 \
        "$child_pid" eth0 \
        4>"$tmpdir/slirp-ready" \
        >/dev/null 2>&1 &
    slirp_pid=$!

    cat "$tmpdir/slirp-ready" >/dev/null 2>/dev/null || true
    printf 'go\n' >&9
    exec 9>&-

    wait "$child_wrapper_pid"
    rc=$?
    kill "$slirp_pid" 2>/dev/null || true
    wait "$slirp_pid" 2>/dev/null || true
    exit "$rc"
fi

SQEXEC_CMD="$cmd" SQEXEC_WORKDIR="$workdir" exec timeout "$timeout_s" \
    unshare --mount --pid --ipc --uts --net --fork \
    "$0" --internal-chroot "$root" 0 - - -
